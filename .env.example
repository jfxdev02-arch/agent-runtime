# Environment Configuration
# Copy this file to .env and fill in your values

# === LLM API (Required) ===
ZAI_ENDPOINT=https://api.example.com/v1/chat/completions
ZAI_API_KEY=your-api-key-here

# === Telegram Bot (Optional) ===
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOW_ID=your-telegram-chat-id

# === Runtime Settings ===
WORKSPACE_ROOT=/home/your-user
PROMPTS_DIR=/home/your-user/agent-runtime/prompts
DB_PATH=/home/your-user/agent-runtime/agent.db
PORT=8080
MAX_HISTORY=25
MAX_TURNS=50
MAX_RUN_SECONDS=0
MAX_TOOL_CALLS=20
LOOP_HISTORY_SIZE=30
LOOP_WARN_AT=10
LOOP_CRITICAL_AT=20
LOOP_GLOBAL_AT=30

# === Agent Identity ===
AGENT_NAME=Cronos
LANGUAGE=en
